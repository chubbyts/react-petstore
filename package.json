{
  "name": "react-petstore",
  "type": "module",
  "description": "A skeleton react app for the petstore api.",
  "keywords": [
    "chubbyts",
    "skleton",
    "react"
  ],
  "author": "Dominik Zogg",
  "license": "MIT",
  "repository": "chubbyts/react-petstore",
  "scripts": {
    "build": "tsc && vite build",
    "cs-fix": "prettier --write src tests *.js *.ts",
    "cs": "prettier --check src tests *.js *.ts",
    "develop": "vite",
    "lint-fix": "eslint src tests *.js *.ts --fix",
    "lint": "eslint src tests",
    "start": "pnpm i && pnpm cs-fix && pnpm develop",
    "test": "vitest"
  },
  "dependencies": {
    "@chubbyts/chubbyts-throwable-to-error": "^2.0.2",
    "@tanstack/react-query": "^5.90.21",
    "cross-fetch": "^4.1.0",
    "date-fns": "^4.1.0",
    "qs": "^6.15.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@chubbyts/chubbyts-function-mock": "^2.0.2",
    "@eslint/js": "^10.0.1",
    "@prettier/sync": "^0.6.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.0",
    "@types/qs": "^6.15.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^10.0.3",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-functional": "^9.0.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "jsdom": "^29.0.0",
    "nock": "^14.0.11",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=20"
  },
  "prettier": {
    "printWidth": 120,
    "tabWidth": 2,
    "singleQuote": true,
    "trailingComma": "all",
    "plugins": [
      "prettier-plugin-tailwindcss"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "@tailwindcss/oxide",
      "esbuild",
      "unrs-resolver"
    ]
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be"
}
